local function fireSpam(cmd)
    pcall(function()
        local signals = ReplicatedStorage:FindFirstChild("HDAdminHDClient")
        if signals then
            signals = signals:FindFirstChild("Signals")
            if signals then
                local createLog = signals:FindFirstChild("CreateLog")
                if createLog and createLog:IsA("RemoteEvent") then
                    createLog:FireServer({Message = cmd, Player = player, LogType = "chatLogs"})
                end
                local requestCmd = signals:FindFirstChild("RequestCommandModification")
                if requestCmd and requestCmd:IsA("RemoteFunction") then
                    requestCmd:InvokeServer(cmd)
                end
            end
        end
    end)
end

startSpamBtn2.MouseButton1Click:Connect(function()
    local cmds = {}
    local text = spamBox.Text
    for c in string.gmatch(text, "[^;\n]+") do
        local cmd = c:match("^%s*(.-)%s*$")
        if cmd ~= "" then table.insert(cmds, cmd) end
    end
    
    if #cmds == 0 then
        spamStatus2.Text = "⚠ لا توجد أوامر!"
        spamStatus2.TextColor3 = Color3.fromRGB(255, 200, 0)
        return
    end
    
    local delay = tonumber(delayBox2.Text) or 1
    delay = math.max(0.1, math.min(10, delay))
    
    spamActive = true
    spamStatus2.Text = "▶ نشط (" .. #cmds .. " أمر)"
    spamStatus2.TextColor3 = Color3.fromRGB(0, 255, 100)
    
    task.spawn(function()
        while spamActive do
            for i = 1, 3 do
                for _, c in pairs(cmds) do
                    if not spamActive then break end
                    task.spawn(function() fireSpam(c) end)
                end
                if not spamActive then break end
            end
            task.wait(delay)
        end
    end)
end)

