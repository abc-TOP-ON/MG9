createToggle("🔕 مضاد الإشعارات", 595, "🔕", function(s) 
    Settings.AntiAlerts = s
    
    if s then
        local function hideAllAlerts()
            pcall(function()
                for _, g in pairs(player.PlayerGui:GetChildren()) do
                    if g:IsA("ScreenGui") then
                        local alertNames = {"HDAdminGui", "MessageGui", "Alert", "Notification", "Notify", "System", "Warning", "Error", "Ban", "Kick", "Spam", "TooFast"}
                        for _, name in pairs(alertNames) do
                            if string.find(g.Name, name) then
                                g.Enabled = false
                                g:Destroy()
                            end
                        end
                    end
                end
                
                for _, g in pairs(player.PlayerGui:GetChildren()) do
                    if g:IsA("ScreenGui") then
                        for _, child in pairs(g:GetDescendants()) do
                            if child:IsA("TextLabel") or child:IsA("TextButton") then
                                local alertWords = {"system", "too fast", "spam", "warning", "error", "alert", "notify", "kick", "ban", "speed", "limit"}
                                for _, word in pairs(alertWords) do
                                    if child.Text and string.find(child.Text:lower(), word) then
                                        local container = child.Parent
                                        while container and container:IsA("Frame") do
                                            container.Visible = false
                                            container:Destroy()
                                            container = container.Parent
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end)
        end
        
        ProtectionThreads.AntiAlerts = task.spawn(function()
            while Settings.AntiAlerts do
                hideAllAlerts()
                task.wait(0.05)
            end
        end)
        
        local function blockNewAlerts(obj)
            if obj:IsA("ScreenGui") then
                local alertNames = {"HDAdminGui", "MessageGui", "Alert", "Notification", "Notify", "System", "Warning", "Error", "Ban", "Kick"}
                for _, name in pairs(alertNames) do
                    if string.find(obj.Name, name) then
                        obj.Enabled = false
                        obj:Destroy()
                    end
                end
            end
            for _, child in pairs(obj:GetChildren()) do
                blockNewAlerts(child)
            end
        end
        
        player.PlayerGui.ChildAdded:Connect(function(child)
            if Settings.AntiAlerts then
                task.wait(0.01)
                blockNewAlerts(child)
            end
        end)
        
        statusLabel.Text = "✅ مضاد الإشعارات مفعل نهائياً"
        statusLabel.TextColor3 = colors.success
    else
        if ProtectionThreads.AntiAlerts then
            task.cancel(ProtectionThreads.AntiAlerts)
            ProtectionThreads.AntiAlerts = nil
        end
        statusLabel.Text = "❌ مضاد الإشعارات معطل"
        statusLabel.TextColor3 = colors.danger
    end
    task.wait(1.5)
    statusLabel.Text = "جاهز للتشغيل"
    statusLabel.TextColor3 = colors.textDim
end)

