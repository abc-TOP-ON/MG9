local function createAlert(message, alertType, duration)
    duration = duration or 3
    
    -- إنشاء إطار التنبيه
    local alertFrame = Instance.new("Frame", gui)
    alertFrame.Size = UDim2.new(0, 350, 0, 50)
    alertFrame.Position = UDim2.new(0.5, -175, 0, 50)
    alertFrame.BackgroundColor3 = colors.bg2
    alertFrame.BackgroundTransparency = 0.1
    createCorner(alertFrame, 12)
    createStroke(alertFrame, colors.primary, 1.5)
    alertFrame.ZIndex = 100
    
    -- ظل للتنبيه
    local shadow = Instance.new("ImageLabel", alertFrame)
    shadow.Size = UDim2.new(1, 30, 1, 30)
    shadow.Position = UDim2.new(0, -15, 0, -15)
    shadow.BackgroundTransparency = 1
    shadow.Image = "rbxassetid://131604529"
    shadow.ImageTransparency = 0.7
    shadow.ZIndex = 0
    
    -- أيقونة التنبيه
    local icon = Instance.new("TextLabel", alertFrame)
    icon.Size = UDim2.new(0, 40, 1, 0)
    icon.Text = alertType == "success" and "✅" or alertType == "warning" and "⚠️" or alertType == "error" and "❌" or "🔔"
    icon.TextColor3 = colors.text
    icon.BackgroundTransparency = 1
    icon.TextSize = 24
    icon.Font = Enum.Font.GothamBold
    
    -- نص التنبيه
    local label = Instance.new("TextLabel", alertFrame)
    label.Size = UDim2.new(1, -80, 1, 0)
    label.Position = UDim2.new(0, 45, 0, 0)
