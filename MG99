local function createCorner(parent, radius)
    local corner = Instance.new("UICorner", parent)
    corner.CornerRadius = UDim.new(0, radius or 12)
end

local function createStroke(parent, color, thickness)
    local stroke = Instance.new("UIStroke", parent)
    stroke.Color = color
    stroke.Thickness = thickness or 2
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    return stroke
end

-- دالة لإنشاء إطار نيترو متحرك (قوس قزح)
local function createNeonFrame(parent, size, position, thickness)
    local frame = Instance.new("Frame", parent)
    frame.Size = size
    frame.Position = position
    frame.BackgroundTransparency = 1
    frame.ZIndex = 0
    
    -- الإطار المتوهج
    local stroke = Instance.new("UIStroke", frame)
    stroke.Thickness = thickness or 3
    stroke.Color = Color3.fromRGB(255, 0, 0)
    stroke.Transparency = 0.3
    
    -- تأثير التوهج (Glow)
    local glow = Instance.new("ImageLabel", frame)
    glow.Size = UDim2.new(1.2, 0, 1.2, 0)
    glow.Position = UDim2.new(-0.1, 0, -0.1, 0)
    glow.BackgroundTransparency = 1
    glow.Image = "rbxassetid://5028857084"  -- تأثير توهج
    glow.ImageColor3 = Color3.fromRGB(255, 0, 255)
    glow.ImageTransparency = 0.5
    glow.ZIndex = 0
    
    -- تحريك الألوان
    task.spawn(function()
        local hue = 0
        while frame.Parent and frame.Visible do
            hue = (hue + 0.005) % 1
            local color = Color3.fromHSV(hue, 1, 1)
            stroke.Color = color
            glow.ImageColor3 = color
            task.wait(0.02)
        end
    end)
    
    return frame
end

