local function setupOneClick(button, callback)
    if not button then return end
    
    -- منع الضغط المتكرر
    local debounce = false
    
    local function handlePress()
        if debounce then return end
        debounce = true
        callback()
        task.wait(0.15) -- منع التكرار السريع
        debounce = false
    end
    
    button.MouseButton1Click:Connect(handlePress)
    button.TouchTap:Connect(handlePress)
    
    -- للهواتف بشكل خاص
    button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            handlePress()
        end
    end)
    
    -- منع الـ Double Tap على الهواتف
    button.TouchLongPress:Connect(function()
        -- لا تفعل شيء لمنع الضغط المطول
    end)
end

