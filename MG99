local function setupDragging(button)
    local dragging = false
    local dragStart = nil
    local startPos = nil
    
    button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = button.Position
            button.ZIndex = 100
            TweenService:Create(button, TweenInfo.new(0.2), {Size = UDim2.new(0, 85, 0, 85)}):Play()
        end
    end)
    
    button.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            local newPos = UDim2.new(
                startPos.X.Scale + delta.X / (button.Parent.AbsoluteSize.X or 1),
                startPos.X.Offset + delta.X,
                startPos.Y.Scale + delta.Y / (button.Parent.AbsoluteSize.Y or 1),
                startPos.Y.Offset + delta.Y
            )
            newPos = UDim2.new(
                math.clamp(newPos.X.Scale, 0, 1 - (button.Size.X.Scale)),
                math.clamp(newPos.X.Offset, 0, button.Parent.AbsoluteSize.X - button.Size.X.Offset),
                math.clamp(newPos.Y.Scale, 0, 1 - (button.Size.Y.Scale)),
                math.clamp(newPos.Y.Offset, 0, button.Parent.AbsoluteSize.Y - button.Size.Y.Offset)
            )
            button.Position = newPos
        end
    end)
    
    button.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
            button.ZIndex = 1
            TweenService:Create(button, TweenInfo.new(0.2), {Size = UDim2.new(0, 75, 0, 75)}):Play()
        end
    end)
end

