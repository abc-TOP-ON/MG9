local function createToggleSwitch(name, pos, desc, callback)
    local frame = Instance.new("Frame", protectContainer)
    frame.Size = UDim2.new(1, 0, 0, 60)
    frame.Position = UDim2.new(0, 0, 0, pos)
    frame.BackgroundColor3 = colors.bg2
    createCorner(frame, 12)
    createStroke(frame, colors.textDim, 0.5)
    
    -- جعل الإطار قابل للنقر بالكامل
    local clickFrame = Instance.new("TextButton", frame)
    clickFrame.Size = UDim2.new(1, 0, 1, 0)
    clickFrame.BackgroundTransparency = 1
    clickFrame.Text = ""
    clickFrame.ZIndex = 0
    
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(0.65, -10, 1, 0)
    label.Position = UDim2.new(0, 15, 0, 0)
    label.Text = name
    label.TextColor3 = colors.text
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.GothamBold
    label.TextSize = 15
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.ZIndex = 1
    
    local subLabel = Instance.new("TextLabel", frame)
    subLabel.Size = UDim2.new(0.65, -10, 0, 18)
    subLabel.Position = UDim2.new(0, 15, 0, 35)
    subLabel.Text = desc or ""
    subLabel.TextColor3 = colors.textDim
    subLabel.BackgroundTransparency = 1
    subLabel.Font = Enum.Font.Gotham
    subLabel.TextSize = 12
    subLabel.TextXAlignment = Enum.TextXAlignment.Left
    subLabel.ZIndex = 1
    
    local toggle = Instance.new("TextButton", frame)
    toggle.Size = UDim2.new(0, 65, 0, 35)
    toggle.Position = UDim2.new(1, -80, 0.5, -17)
    toggle.BackgroundColor3 = colors.danger
    toggle.Text = "OFF"
    toggle.TextColor3 = colors.text
    toggle.Font = Enum.Font.GothamBold
    toggle.TextSize = 14
    createCorner(toggle, 17)
    createStroke(toggle, colors.danger, 2)
    toggle.ZIndex = 2
    
    local state = false
    
    local function toggleState()
        state = not state
        toggle.BackgroundColor3 = state and colors.success or colors.danger
        toggle.Text = state and "ON" or "OFF"
        toggle.UIStroke.Color = state and colors.success or colors.danger
        callback(state)
    end
    
    -- جعل الضغط على أي مكان في الإطار يغير الحالة
    clickFrame.MouseButton1Click:Connect(toggleState)
    toggle.MouseButton1Click:Connect(toggleState)
    
    return toggle
end

