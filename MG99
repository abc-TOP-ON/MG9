local function loadCustomCommands()
    -- تحميل الأوامر المحفوظة
    local saved = getgenv and getgenv().MG9_Commands or {}
    customCommands = saved
    return customCommands
end

local function saveCustomCommands()
    if getgenv then
        getgenv().MG9_Commands = customCommands
    end
end

-- دالة إضافة أمر مخصص
local function addCustomCommand(name, command)
    if #customCommands >= 6 then
        showAlert("⚠️ لا يمكن إضافة أكثر من 6 أوامر!", "warning")
        return false
    end
    if name == "" or command == "" then
        showAlert("⚠️ اسم الأمر أو الأمر فارغ!", "warning")
        return false
    end
    table.insert(customCommands, {name = name, command = command})
    saveCustomCommands()
    showAlert("✅ تم إضافة الأمر: " .. name, "success")
    return true
end

-- دالة حذف أمر مخصص
local function removeCustomCommand(index)
    if customCommands[index] then
        local name = customCommands[index].name
        table.remove(customCommands, index)
        saveCustomCommands()
        showAlert("❌ تم حذف الأمر: " .. name, "error")
        return true
    end
    return false
end

-- تحميل الأوامر عند التشغيل
loadCustomCommands()

