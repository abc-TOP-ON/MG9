    label.TextColor3 = colors.text
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.GothamBold
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    
    -- زر إغلاق التنبيه
    local closeAlert = Instance.new("TextButton", alertFrame)
    closeAlert.Size = UDim2.new(0, 30, 0, 30)
    closeAlert.Position = UDim2.new(1, -35, 0.5, -15)
    closeAlert.Text = "✕"
    closeAlert.TextColor3 = colors.danger
    closeAlert.BackgroundTransparency = 1
    closeAlert.TextSize = 16
    closeAlert.Font = Enum.Font.GothamBold
    
    -- تأثير الدخول
    alertFrame.Position = UDim2.new(0.5, -175, 0, -60)
    local tween = TweenService:Create(alertFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {
        Position = UDim2.new(0.5, -175, 0, 50)
    })
    tween:Play()
    
    -- إغلاق التنبيه
    closeAlert.MouseButton1Click:Connect(function()
        alertFrame:Destroy()
    end)
    
    closeAlert.TouchTap:Connect(function()
        alertFrame:Destroy()
    end)
    
    -- إغلاق تلقائي
    task.spawn(function()
        task.wait(duration)
        if alertFrame then
            local tween2 = TweenService:Create(alertFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {
                Position = UDim2.new(0.5, -175, 0, -60)
            })
            tween2:Play()
            task.wait(0.6)
            alertFrame:Destroy()
        end
    end)
    
    return alertFrame
end

