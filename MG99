local toggleLogs = createToggleSwitch("📋 مضاد اللاق (Logs)", 120, "يمنع تنفيذ أوامر اللاق", function(state)
    _G.AntiLogs = state
    if state then
        local function secureRemote(remote)
            if remote:IsA("RemoteEvent") and remote.Name == "ExecuteClientCommand" then
                if getconnections then
                    for _, conn in pairs(getconnections(remote.OnClientEvent)) do
                        conn:Disable()
                    end
                end
                remote.OnClientEvent:Connect(function() return nil end)
            end
        end
        for _, v in pairs(ReplicatedStorage:GetDescendants()) do secureRemote(v) end
        ReplicatedStorage.DescendantAdded:Connect(function(d)
            if _G.AntiLogs then secureRemote(d) end
        end)
    end
end)

