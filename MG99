-- 9. Hyper-Precision Micro-Float Pipeline Engine
local function StreamFloatingPercentages(endGoal, timeframe)
    local currentFloatVal = tonumber(string.match(PrecisionCounter.Text, "[%d%.]+")) or 0
    local elapsedDelta = 0
    
    while elapsedDelta < timeframe do
        local stepTime = RunService.RenderStepped:Wait()
        elapsedDelta = math.min(elapsedDelta + stepTime, timeframe)
        
        -- High end quintic fluid loading curves
        local completionRatio = elapsedDelta / timeframe
        local smoothQuintic = 1 - math.pow(1 - completionRatio, 5)
        
        local framePrecisionValue = currentFloatVal + ((endGoal - currentFloatVal) * smoothQuintic)
        PrecisionCounter.Text = string.format("%.4f%%", framePrecisionValue)
    end
end

