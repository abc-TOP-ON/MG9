local function DeployOrbitalVortex()
    local orbits = {}
    local maxNodes = 36
    
    for i = 1, maxNodes do
        local node = Instance.new("Frame")
        node.Size = UDim2.new(0, math.random(2, 4), 0, math.random(2, 4))
        node.BackgroundColor3 = Color3.fromRGB(0, 255, 150)
        node.BackgroundTransparency = math.random(3, 8) / 10
        node.BorderSizePixel = 0
        node.Parent = VortexContainer
        
        local rounding = Instance.new("UICorner")
        rounding.CornerRadius = UDim.new(1, 0)
        rounding.Parent = node
        
        table.insert(orbits, {
            element = node,
            radius = math.random(110, 230),
            angle = (i * (360 / maxNodes)),
            speed = math.random(15, 45) / 10
        })
    end
    
    local runConnection
    runConnection = RunService.RenderStepped:Connect(function(deltaTime)
        if not ScreenGui or not ScreenGui.Parent then runConnection:Disconnect() return end
        for _, orb in ipairs(orbits) do
            orb.angle = orb.angle + (orb.speed * deltaTime * 30)
            local rad = math.rad(orb.angle)
            
            -- Polar vector calculations mapping UI elements into absolute circular motion
            local xOffset = math.cos(rad) * orb.radius
            local yOffset = math.sin(rad) * orb.radius
            
            orb.element.Position = UDim2.new(0.5, xOffset, 0.5, yOffset)
        end
    end)
end
