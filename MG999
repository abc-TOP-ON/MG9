local function createStarsEffect(parent)
    local stars = {}
    for i = 1, 50 do
        local star = Instance.new("Frame", parent)
        star.Size = UDim2.new(0, math.random(1, 3), 0, math.random(1, 3))
        star.Position = UDim2.new(math.random() / 2, 0, math.random() / 2, 0)
        star.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        star.BackgroundTransparency = math.random(30, 80) / 100
        star.ZIndex = 0
        createCorner(star, 5)
        
        table.insert(stars, {
            frame = star,
            speed = 0.5 + math.random() * 2,
            direction = math.random(0, 360),
            twinkleSpeed = 0.5 + math.random() * 2
        })
    end
    
    task.spawn(function()
        while true do
            for _, star in pairs(stars) do
                if star.frame and star.frame.Parent then
                    local pos = star.frame.Position
                    local newX = pos.X.Scale + 0.001 * star.speed
                    local newY = pos.Y.Scale + 0.0005 * star.speed
                    if newX > 1 then newX = 0 end
                    if newY > 1 then newY = 0 end
                    star.frame.Position = UDim2.new(newX, 0, newY, 0)
                    
                    local trans = star.frame.BackgroundTransparency
                    trans = trans + math.sin(tick() * star.twinkleSpeed) * 0.01
                    star.frame.BackgroundTransparency = math.clamp(trans, 0.1, 0.9)
                end
            end
            task.wait(0.05)
        end
    end)
    
    return stars
end

local function createWavesEffect(parent)
    local waves = {}
    for i = 1, 3 do
        local wave = Instance.new("Frame", parent)
        wave.Size = UDim2.new(2, 0, 0, math.random(2, 5))
        wave.Position = UDim2.new(-0.5, 0, 0.2 + (i-1) * 0.3, 0)
        wave.BackgroundColor3 = getThemeColors(currentTheme).primary
        wave.BackgroundTransparency = 0.7
        wave.ZIndex = 0
        createCorner(wave, 20)
        
        table.insert(waves, {
            frame = wave,
            speed = 0.5 + i * 0.3,
            amplitude = 0.05 + i * 0.02,
            offset = i * 2
        })
    end
    
    task.spawn(function()
        while true do
            for _, wave in pairs(waves) do
                if wave.frame and wave.frame.Parent then
                    local time = tick() * wave.speed + wave.offset
                    local y = 0.2 + math.sin(time) * 0.1 + 0.3 * ((wave.offset / 2) % 1)
                    wave.frame.Position = UDim2.new(-0.5 + math.sin(time * 0.5) * 0.5, 0, y, 0)
                    
                    local colors = getThemeColors(currentTheme)
                    wave.frame.BackgroundColor3 = colors.primary
                    wave.frame.BackgroundTransparency = 0.5 + math.sin(time * 1.5) * 0.2
                end
            end
            task.wait(0.03)
        end
    end)
    
    return waves
end

local function createParticlesEffect(parent)
    local particles = {}
    for i = 1, 30 do
        local particle = Instance.new("Frame", parent)
        local size = math.random(2, 6)
        particle.Size = UDim2.new(0, size, 0, size)
        particle.Position = UDim2.new(math.random() / 2, 0, math.random() / 2, 0)
        particle.BackgroundColor3 = getThemeColors(currentTheme).primary
        particle.BackgroundTransparency = 0.3
        particle.ZIndex = 0
        createCorner(particle, size)
        
        table.insert(particles, {
            frame = particle,
            vx = (math.random() - 0.5) * 0.005,
            vy = (math.random() - 0.5) * 0.005,
            size = size,
            life = 1,
            maxLife = 3 + math.random() * 5,
            age = 0,
        })
    end
    
    task.spawn(function()
        while true do
            for _, p in pairs(particles) do
                if p.frame and p.frame.Parent then
                    p.age = p.age + 0.02
                    p.life = 1 - (p.age / p.maxLife)
                    
                    if p.life <= 0 then
                        p.frame.Position = UDim2.new(math.random() / 2, 0, math.random() / 2, 0)
                        p.age = 0
                        p.life = 1
                        p.vx = (math.random() - 0.5) * 0.005
                        p.vy = (math.random() - 0.5) * 0.005
                        p.maxLife = 3 + math.random() * 5
                    end
                    
                    local pos = p.frame.Position
                    p.frame.Position = UDim2.new(
                        pos.X.Scale + p.vx + math.sin(tick() * 2 + p.size) * 0.0005,
                        0,
                        pos.Y.Scale + p.vy + math.cos(tick() * 2 + p.size) * 0.0005,
                        0
                    )
                    
                    p.frame.BackgroundTransparency = 0.3 + (1 - p.life) * 0.5
                    
                    local colors = getThemeColors(currentTheme)
                    p.frame.BackgroundColor3 = colors.primary
                    p.frame.Size = UDim2.new(0, p.size * p.life, 0, p.size * p.life)
                end
            end
            task.wait(0.03)
        end
    end)
    
    return particles
end

local function createGradientEffect(parent)
    local gradientFrame = Instance.new("Frame", parent)
    gradientFrame.Size = UDim2.new(1, 0, 1, 0)
    gradientFrame.BackgroundTransparency = 1
    gradientFrame.ZIndex = 0
    
    local gradient = Instance.new("UIGradient", gradientFrame)
    local colors = getThemeColors(currentTheme)
    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, colors.primary),
        ColorSequenceKeypoint.new(0.3, colors.secondary),
        ColorSequenceKeypoint.new(0.6, colors.accent),
        ColorSequenceKeypoint.new(1, colors.primary)
    })
    gradient.Rotation = 0
    
    task.spawn(function()
        while true do
            gradient.Rotation = (gradient.Rotation + 0.5) % 360
            task.wait(0.05)
        end
    end)
    
    return {frame = gradientFrame, gradient = gradient}
end

local function startBackgroundEffect(effectName, parent)
    if BackgroundThread then
        BackgroundThread = nil
    end
    
    for _, child in pairs(parent:GetChildren()) do
        if child:IsA("Frame") and child.ZIndex == 0 and child.Name ~= "bgGradient" then
            child:Destroy()
        end
    end
    
    local effect = nil
    if effectName == "stars" then
        effect = createStarsEffect(parent)
    elseif effectName == "waves" then
        effect = createWavesEffect(parent)
    elseif effectName == "particles" then
        effect = createParticlesEffect(parent)
    elseif effectName == "gradient" then
        effect = createGradientEffect(parent)
    end
    
    return effect
end

