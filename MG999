    local center = {
        X = button.Position.X.Scale + button.Size.X.Scale / 2,
        Y = button.Position.Y.Scale + button.Size.Y.Scale / 2
    }
    
    local effects = {
        function() createStarExplosion(parent, center, colors.primary) end,
        function() createFlashEffect(parent, colors.primary) end,
        function() createExpandingCircles(parent, center, colors.primary) end,
