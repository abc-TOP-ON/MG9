local function createAnimatedHeaderButton(parent, text, color, posX, animationType)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0, 35, 0, 35)
    btn.Position = UDim2.new(1, posX, 0.5, -17.5)
    btn.Text = text
    btn.TextColor3 = color
    btn.BackgroundTransparency = 1
    btn.TextSize = 20
    btn.Font = Enum.Font.GothamBold
    btn.ZIndex = 10
    btn.AutoButtonColor = true
    
    local animating = false
    
    btn.MouseEnter:Connect(function()
        if animating then return end
        animating = true
        
        TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextSize = 26}):Play()
        
        if animationType == "spin" then
            TweenService:Create(btn, TweenInfo.new(1, Enum.EasingStyle.Quad), {Rotation = 360}):Play()
        elseif animationType == "bounce" then
            local bounce = TweenInfo.new(0.3, Enum.EasingStyle.Bounce)
            TweenService:Create(btn, bounce, {Position = UDim2.new(1, posX, 0.5, -22)}):Play()
            task.wait(0.3)
            TweenService:Create(btn, bounce, {Position = UDim2.new(1, posX, 0.5, -17.5)}):Play()
        elseif animationType == "pulse" then
            for i = 1, 3 do
                TweenService:Create(btn, TweenInfo.new(0.15), {TextTransparency = 0.5}):Play()
                task.wait(0.15)
                TweenService:Create(btn, TweenInfo.new(0.15), {TextTransparency = 0}):Play()
                task.wait(0.15)
            end
        elseif animationType == "glow" then
            local glowColor = btn.TextColor3
            for i = 1, 3 do
                btn.TextColor3 = colors.primary
                task.wait(0.1)
                btn.TextColor3 = glowColor
                task.wait(0.1)
            end
        end
        
        animating = false
    end)
    
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {TextSize = 20, Rotation = 0}):Play()
        btn.Position = UDim2.new(1, posX, 0.5, -17.5)
    end)
    
    return btn
end

