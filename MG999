local function createExpandingCircles(parent, position, color)
    for i = 1, 3 do
        local circle = Instance.new("Frame", parent)
        circle.Size = UDim2.new(0, 5, 0, 5)
        circle.Position = UDim2.new(
            position.X.Scale - 0.5 * (5 / parent.AbsoluteSize.X or 1),
            position.X.Offset - 2.5,
            position.Y.Scale - 0.5 * (5 / parent.AbsoluteSize.Y or 1),
            position.Y.Offset - 2.5
        )
        circle.BackgroundColor3 = color or colors.primary
        circle.BackgroundTransparency = 0.3
        circle.ZIndex = 101
        createCorner(circle, 100)
        
        local size = 20 + i * 20
        local delay = i * 0.1
        local info = TweenInfo.new(0.6 + i * 0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        
        task.wait(delay)
        TweenService:Create(circle, info, {
            Size = UDim2.new(0, size, 0, size),
            Position = UDim2.new(
                position.X.Scale - 0.5 * (size / parent.AbsoluteSize.X or 1),
                position.X.Offset - size/2,
                position.Y.Scale - 0.5 * (size / parent.AbsoluteSize.Y or 1),
                position.Y.Offset - size/2
            ),
            BackgroundTransparency = 1
        }):Play()
        
        task.wait(0.6 + i * 0.1)
        circle:Destroy()
    end
end

local function createParticleBurst(parent, position, color)
    local particles = {}
    for i = 1, 12 do
        local particle = Instance.new("Frame", parent)
        local size = math.random(3, 6)
        particle.Size = UDim2.new(0, size, 0, size)
        particle.Position = UDim2.new(
            position.X.Scale,
            position.X.Offset,
            position.Y.Scale,
            position.Y.Offset
        )
        particle.BackgroundColor3 = color or colors.primary
        particle.BackgroundTransparency = 0.2
        particle.ZIndex = 100
        createCorner(particle, size)
        
        local angle = math.rad(i * 30 + math.random(-10, 10))
        local distance = math.random(30, 80)
        local targetX = position.X.Offset + math.cos(angle) * distance
        local targetY = position.Y.Offset + math.sin(angle) * distance
        
        local info = TweenInfo.new(0.4 + math.random() * 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        TweenService:Create(particle, info, {
            Position = UDim2.new(
                position.X.Scale + (targetX / parent.AbsoluteSize.X or 1),
                targetX,
                position.Y.Scale + (targetY / parent.AbsoluteSize.Y or 1),
                targetY
            ),
            BackgroundTransparency = 1,
            Size = UDim2.new(0, size * 0.5, 0, size * 0.5)
        }):Play()
        
        table.insert(particles, particle)
    end
    
    task.wait(0.6)
    for _, p in pairs(particles) do
        p:Destroy()
    end
end

