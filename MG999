local function fireSpam(cmd)
    if SmartSpam.Active then
        local success, result = pcall(function()
            return ReplicatedStorage.HDAdminHDClient.Signals.RequestCommandModification:InvokeServer(cmd)
        end)
        
        if success and result and type(result) == "string" then
            SmartSpam.LastResponse = result:lower()
            
            local spamKeywords = {"too fast", "spam", "slow down", "rate limit", "cooldown", "wait", "slow"}
            for _, keyword in ipairs(spamKeywords) do
                if string.find(SmartSpam.LastResponse, keyword) then
                    SmartSpam.DetectedSpam = true
                    SmartSpam.ResponseCount = SmartSpam.ResponseCount + 1
                    
                    if SmartSpam.AutoAdjustSpeed then
                        SmartSpam.CurrentSpeed = math.min(SmartSpam.CurrentSpeed + 0.005, SmartSpam.MaxSpeed)
                        speedBox.Text = string.format("%.3f", SmartSpam.CurrentSpeed)
                    end
                    
                    if SmartSpam.ResponseCount >= SmartSpam.MaxResponseCount then
                        Spam.Active = false
                        statusLabel.Text = "⚠️ تم اكتشاف سبام! توقف تلقائياً"
                        statusLabel.TextColor3 = colors.warning
                        
                        task.spawn(function()
                            task.wait(5)
                            SmartSpam.ResponseCount = 0
                            SmartSpam.DetectedSpam = false
                            if SmartSpam.AutoAdjustSpeed then
                                SmartSpam.CurrentSpeed = SmartSpam.MinSpeed
                                speedBox.Text = string.format("%.3f", SmartSpam.CurrentSpeed)
                            end
                            statusLabel.Text = "🔄 جاهز للتكرار من جديد"
                            statusLabel.TextColor3 = colors.success
                            task.wait(2)
                            statusLabel.Text = "جاهز للتشغيل"
                            statusLabel.TextColor3 = colors.textDim
                        end)
                        
                        return false
                    end
                    
                    return false
                end
            end
        end
        
        if SmartSpam.AutoAdjustSpeed and not SmartSpam.DetectedSpam then
            if SmartSpam.CurrentSpeed > SmartSpam.MinSpeed then
                SmartSpam.CurrentSpeed = math.max(SmartSpam.CurrentSpeed - 0.001, SmartSpam.MinSpeed)
                speedBox.Text = string.format("%.3f", SmartSpam.CurrentSpeed)
            end
        end
        
        return true
    else
        pcall(function()
            ReplicatedStorage.HDAdminHDClient.Signals.CreateLog:FireServer({Message = cmd, Player = player, LogType = "chatLogs"})
        end)
        pcall(function()
            ReplicatedStorage.HDAdminHDClient.Signals.RequestCommandModification:InvokeServer(cmd)
        end)
        return true
    end
end

