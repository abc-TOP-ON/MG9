local function startAdvancedProtection(category, subKey)
    local config = AdvancedProtection[category]
    if not config then return end
    
    stopAdvancedProtection(category, subKey)
    
    if category == "AntiLag" then
        ProtectionTimers.AntiLag = task.spawn(function()
            while config.Enabled do
                pcall(function()
                    if config.Mode == "aggressive" then
                        for _, effect in pairs(workspace:GetDescendants()) do
                            if effect:IsA("ParticleEmitter") then
                                effect.Enabled = false
                            elseif effect:IsA("Trail") then
                                effect.Enabled = false
                            elseif effect:IsA("Smoke") then
                                effect.Enabled = false
                            elseif effect:IsA("Fire") then
                                effect.Enabled = false
                            elseif effect:IsA("Sparkles") then
                                effect.Enabled = false
                            end
                        end
                        
                        Lighting.GlobalShadows = false
                        Lighting.FogEnd = 1000
                        Lighting.FogStart = 500
                        
                    elseif config.Mode == "balanced" then
                        for _, effect in pairs(workspace:GetDescendants()) do
                            if effect:IsA("ParticleEmitter") and effect.Enabled then
                                effect.Rate = math.min(effect.Rate, 50)
                            end
                        end
                    end
                    
                    if config.AutoFix then
                        local success, result = pcall(function()
                            if game:GetService("NetworkClient") then
                                game:GetService("NetworkClient"):SetOutgoingKBPSLimit(0)
                            end
                        end)
                    end
                end)
                task.wait(1)
            end
        end)
        
    elseif category == "AntiExplosion" then
        ProtectionTimers.AntiExplosion = task.spawn(function()
            while config.Enabled do
                pcall(function()
                    if config.RemoveExplosions then
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v:IsA("Explosion") then
                                v:Destroy()
                            end
                            if v:IsA("BasePart") and v.Name:lower():find("explosion") then
                                v:Destroy()
                            end
                        end
                    end
                    
                    if config.RemoveFire then
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v:IsA("Fire") then
                                v:Destroy()
                            end
                        end
                    end
                    
                    if config.RemoveSmoke then
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v:IsA("Smoke") then
                                v:Destroy()
                            end
                            if v:IsA("Smoke") or (v:IsA("ParticleEmitter") and v.Name:lower():find("smoke")) then
                                v:Destroy()
                            end
                        end
                    end
                    
                    if config.RemoveSparks then
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v:IsA("Sparkles") then
                                v:Destroy()
                            end
                        end
                    end
                    
                    if config.ProtectBuildings then
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v:IsA("BasePart") and v.Anchored == false and v:GetMass() > 500 then
                                v.Anchored = true
                            end
                        end
                    end
                    
                    ProtectionStats.BlocksCount = ProtectionStats.BlocksCount + 1
                end)
                task.wait(0.5)
            end
        end)
        
    elseif category == "AntiRealism" then
        ProtectionTimers.AntiRealism = task.spawn(function()
            while config.Enabled do
                pcall(function()
                    if config.RemoveFog then
                        Lighting.FogEnd = 100000
                        Lighting.FogStart = 0
                        Lighting.Atmosphere.FogEnd = 100000
                        Lighting.Atmosphere.FogStart = 0
                    end
                    
                    if config.RemoveBloom then
                        for _, v in pairs(Lighting:GetChildren()) do
                            if v:IsA("BloomEffect") then
                                v.Enabled = false
                            end
                        end
                    end
                    
                    if config.RemoveMotionBlur then
                        for _, v in pairs(Lighting:GetChildren()) do
                            if v:IsA("MotionBlurEffect") then
                                v.Enabled = false
                            end
                        end
                    end
                    
                    if config.RemoveDepthOfField then
                        for _, v in pairs(Lighting:GetChildren()) do
                            if v:IsA("DepthOfFieldEffect") then
                                v.Enabled = false
                            end
                        end
                    end
                    
                    if config.RemoveColorCorrection then
                        for _, v in pairs(Lighting:GetChildren()) do
                            if v:IsA("ColorCorrectionEffect") then
                                v.Enabled = false
                            end
                        end
                    end
                    
                    if config.RemoveSunRays then
                        for _, v in pairs(Lighting:GetChildren()) do
                            if v:IsA("SunRaysEffect") then
                                v.Enabled = false
                            end
                        end
                    end
                    
                    if config.FixBrightness then
                        Lighting.Brightness = 1.5
                        Lighting.ExposureCompensation = 0
                    end
                    
                    local cam = workspace.CurrentCamera
                    if cam and cam:FindFirstChildOfClass("Camera") then
                        for _, v in pairs(cam:GetChildren()) do
                            if v:IsA("PostProcessing") then
                                v.Enabled = false
                            end
                        end
                    end
                end)
                task.wait(0.5)
            end
        end)
        
    elseif category == "FPSBoost" then
        ProtectionTimers.FPSBoost = task.spawn(function()
            while config.Enabled do
                pcall(function()
                    local level = config.Level
                    
                    if config.DisableShadows then
                        Lighting.ShadowSoftness = 0
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v:IsA("BasePart") and v.Material == Enum.Material.SmoothPlastic then
                                v.CastShadow = false
                            end
                        end
                    end
                    
                    if config.DisableParticles then
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v:IsA("ParticleEmitter") then
                                v.Enabled = false
                            end
                            if v:IsA("Trail") then
                                v.Enabled = false
                            end
                        end
                    end
                    
                    if config.ReduceGraphics then
                        if level == "ultra" then
                            settings().Rendering.QualityLevel = 1
                            settings().Rendering.FrameRateLimit = 60
                        elseif level == "high" then
                            settings().Rendering.QualityLevel = 4
                            settings().Rendering.FrameRateLimit = 120
                        elseif level == "medium" then
                            settings().Rendering.QualityLevel = 6
                            settings().Rendering.FrameRateLimit = 240
                        end
                    end
                    
                    if config.DisableWater then
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v:IsA("Water") or v:IsA("Terrain") then
                                v.WaterTransparency = 1
                            end
                        end
                    end
                end)
                task.wait(2)
            end
        end)
        
    elseif category == "AntiFreeze" then
        ProtectionTimers.AntiFreeze = task.spawn(function()
            local lastPosition = nil
            local freezeTime = 0
            
            while config.Enabled do
                pcall(function()
                    local char = player.Character
                    if char and char:FindFirstChild("HumanoidRootPart") then
                        local hrp = char.HumanoidRootPart
                        local currentPos = hrp.Position
                        
                        if lastPosition then
                            local distance = (currentPos - lastPosition).Magnitude
                            if distance < 0.01 then
                                freezeTime = freezeTime + config.CheckInterval
                                if freezeTime > config.MaxFreezeTime and config.AutoReset then
                                    char:BreakJoints()
                                    player:LoadCharacter()
                                    freezeTime = 0
                                    ProtectionStats.ThreatsDetected = ProtectionStats.ThreatsDetected + 1
                                    statusLabel.Text = "❄️ تم اكتشاف تجميد - إعادة تعيين"
                                    statusLabel.TextColor3 = colors.warning
                                end
                            else
                                freezeTime = 0
                            end
                        end
                        lastPosition = currentPos
                    end
                end)
                task.wait(config.CheckInterval)
            end
        end)
        
    elseif category == "AntiFlingPlus" then
        ProtectionTimers.AntiFlingPlus = task.spawn(function()
            local lastVelocity = Vector3.new(0, 0, 0)
            local safePos = nil
            
            while config.Enabled do
                pcall(function()
                    local char = player.Character
                    if char and char:FindFirstChild("HumanoidRootPart") then
                        local hrp = char.HumanoidRootPart
                        local velocity = hrp.Velocity
                        local magnitude = velocity.Magnitude
                        
                        local strength = config.Strength
                        local limit = strength == "extreme" and 80 or 
                                     strength == "high" and 150 or 
                                     strength == "medium" and 250 or 400
                        
                        if magnitude > limit then
                            hrp.Velocity = Vector3.new(0, 0, 0)
                            hrp.RotVelocity = Vector3.new(0, 0, 0)
                            
                            if config.TeleportToSafe and safePos then
                                hrp.CFrame = safePos
                            end
                            
                            ProtectionStats.BlocksCount = ProtectionStats.BlocksCount + 1
                            ProtectionStats.LastBlock = "Fling"
                            
                        elseif config.AntiBounce and magnitude < 1 and velocity.Y < -0.1 then
                            hrp.Velocity = Vector3.new(0, 0, 0)
                        end
                        
                        if magnitude < 10 then
                            safePos = hrp.CFrame
                        end
                    end
                end)
                task.wait(0.1)
            end
        end)
        
    elseif category == "AntiHack" then
        ProtectionTimers.AntiHack = task.spawn(function()
            while config.Enabled do
                pcall(function()
                    if config.BlockInjection then
                        for _, v in pairs(game:GetDescendants()) do
                            if v:IsA("LocalScript") or v:IsA("ModuleScript") then
                                if v.Name:find("Inject") or v.Name:find("Hack") or v.Name:find("Exploit") then
                                    v:Destroy()
                                end
                            end
                        end
                    end
                    
                    if config.BlockSpeedHack then
                        local char = player.Character
                        if char then
                            local hum = char:FindFirstChildOfClass("Humanoid")
                            if hum and hum.WalkSpeed > 50 then
                                hum.WalkSpeed = 16
                                ProtectionStats.ThreatsDetected = ProtectionStats.ThreatsDetected + 1
                            end
                        end
                    end
                    
                    if config.BlockFlyHack then
                        local char = player.Character
                        if char and char:FindFirstChild("Humanoid") then
                            local hum = char.Humanoid
                            if hum.PlatformStand then
                                hum.PlatformStand = false
                            end
                            if hum.Sit then
                                hum.Sit = false
                            end
                        end
                    end
                    
                    if config.BlockNoClip then
                        local char = player.Character
                        if char then
                            for _, part in pairs(char:GetChildren()) do
                                if part:IsA("BasePart") and part.CanCollide == false then
                                    part.CanCollide = true
                                end
                            end
                        end
                    end
                end)
                task.wait(0.5)
            end
        end)
        
    elseif category == "CleanWorld" then
        ProtectionTimers.CleanWorld = task.spawn(function()
            while config.Enabled do
                pcall(function()
                    if config.RemoveDecals then
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v:IsA("Decal") then
                                v:Destroy()
                            end
                            if v:IsA("Texture") then
                                v:Destroy()
                            end
                        end
                    end
                    
                    if config.RemoveEffects then
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v:IsA("Sparkles") or 
                               v:IsA("Fire") or 
                               v:IsA("Smoke") or 
                               v:IsA("Trail") then
                                v:Destroy()
                            end
                        end
                    end
                    
                    if config.RemoveUnnecessary then
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v:IsA("Part") and v.Name:find("Debris") then
                                v:Destroy()
                            end
                            if v:IsA("Part") and v.Material == Enum.Material.Foil then
                                v:Destroy()
                            end
                        end
                    end
                    
                    if config.ClearDebris then
                        game:GetService("Debris"):Clear()
                    end
                end)
                task.wait(2)
            end
        end)
    end
end

local function stopAdvancedProtection(category, subKey)
    local timerName = nil
    
    if category == "AntiLag" then
        timerName = "AntiLag"
    elseif category == "AntiExplosion" then
        timerName = "AntiExplosion"
    elseif category == "AntiRealism" then
        timerName = "AntiRealism"
    elseif category == "FPSBoost" then
        timerName = "FPSBoost"
    elseif category == "AntiFreeze" then
        timerName = "AntiFreeze"
    elseif category == "AntiFlingPlus" then
        timerName = "AntiFlingPlus"
    elseif category == "AntiHack" then
        timerName = "AntiHack"
    elseif category == "CleanWorld" then
        timerName = "CleanWorld"
    end
    
    if timerName and ProtectionTimers[timerName] then
        task.cancel(ProtectionTimers[timerName])
        ProtectionTimers[timerName] = nil
    end
end

game:BindToClose(function()
    for _, timer in pairs(ProtectionTimers) do
        if timer then
            task.cancel(timer)
        end
    end
end)

